generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}




model User {
  id                     String             @id @default(uuid())
  email                  String             @unique
  name                   String?
  phone                  String?
  role                   String             @default("STUDENT")
  password               String             @default("")
  otp                    String?
  isVerified             Boolean            @default(false)
  otpExpiry              DateTime?
  resetOtp               String?
  resetOtpExpiry         DateTime?
  status                 String             @default("APPROVED")
  avatar                 String?
  lastLogin              DateTime?
  streak                 Int                @default(0)
  learnupId              String?            @unique
  provider               String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  certificates           Certificate[]
  courses                Course[]           @relation("InstructorCourses")
  enrolled               CourseEnrollment[]
  liveSessions           LiveSession[]      @relation("InstructorLiveSessions")
  mentorMessages         MentorMessage[]
  notifications          Notification[]
  submissions            Submission[]
  supportTickets         SupportTicket[]
  instructorTransactions Transaction[]      @relation("InstructorTransactions")
  studentTransactions    Transaction[]      @relation("StudentTransactions")
  wallet                 Wallet?
  instructor             Instructor?
}

model Instructor {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isApproved  Boolean  @default(false)
  cvUrl       String?
  degreeUrl   String?
  collegeName String?
  courseName  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Course {
  id           String             @id @default(uuid())
  title        String
  description  String?
  image        String?
  thumbnailUrl String?
  price        Float              @default(0.0)
  instructorId String
  modules      Json?
  template     String?
  isFree       Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  certificates Certificate[]
  instructor   User               @relation("InstructorCourses", fields: [instructorId], references: [id])
  enrollments  CourseEnrollment[]
  liveSessions LiveSession[]
  quizzes      Quiz[]
  resources    Resource[]
  transactions Transaction[]
  videoModules VideoModule[]

  @@index([instructorId])
}

model CourseEnrollment {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@index([courseId])
}

model Quiz {
  id          String       @id @default(uuid())
  title       String
  description String?
  image       String?
  courseId    String
  questions   Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions Submission[]
}

model Submission {
  id             String          @id @default(uuid())
  studentId      String
  quizId         String
  score          Int
  answers        Json
  status         String          @default("PENDING")
  submittedAt    DateTime        @default(now())
  mentorMessages MentorMessage[]
  quiz           Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student        User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model MentorMessage {
  id           String     @id @default(uuid())
  submissionId String
  senderId     String
  message      String
  createdAt    DateTime   @default(now())
  sender       User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id                String   @id @default(uuid())
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  userId            String
  courseId          String?
  instructorId      String?
  amount            Float
  adminShare        Float    @default(0.0)
  instShare         Float    @default(0.0)
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  course            Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor        User?    @relation("InstructorTransactions", fields: [instructorId], references: [id], onDelete: Cascade)
  student           User     @relation("StudentTransactions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@index([instructorId])
}

model Payout {
  id               String   @id @default(uuid())
  razorpayPayoutId String?  @unique
  userId           String
  amount           Float
  status           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model AdminSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Float    @default(20000.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VideoModule {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  videoUrl  String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Certificate {
  id         String   @id @default(uuid())
  studentId  String
  courseId   String
  issueDate  DateTime @default(now())
  pdfUrl     String
  uniqueCode String   @unique
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id           String    @id @default(uuid())
  courseId     String
  instructorId String
  roomName     String    @unique
  isLive       Boolean   @default(false)
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor   User      @relation("InstructorLiveSessions", fields: [instructorId], references: [id], onDelete: Cascade)
}

model Resource {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  url       String
  type      String   @default("PDF")
  size      String   @default("0 KB")
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model StudentDeletedResource {
  id         String   @id @default(uuid())
  userId     String
  resourceId String
  deletedAt  DateTime @default(now())

  @@unique([userId, resourceId])
  @@index([userId])
}
